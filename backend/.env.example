# Environment
ENV=development

# CORS
# Comma-separated origins that can call the backend from browsers
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for dynamic preview domains (e.g., Vercel previews)
CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$

# MongoDB
MONGODB_URL=mongodb+srv://klprathyusha:<password>@cluster0.j7hxulj.mongodb.net/meeting_tasks?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=meeting_tasks

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=uploads/transcripts
MAX_UPLOAD_SIZE_MB=10

# NLP Pipeline
NLP_PIPELINE_PATH=../meeting-action-extractor/src

# Environment
ENV=development

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=meeting_tasks

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=uploads/transcripts
MAX_UPLOAD_SIZE_MB=10

# NLP Pipeline
NLP_PIPELINE_PATH=../meeting-action-extractor/src
